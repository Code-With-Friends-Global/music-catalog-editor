# Copy this file to .env and fill in your key — never commit .env
# q_API_KEY=
AI_SERVICE_PORT=3001

# Main GCP project used for Cloud Run/Cloud Build deploys (paul account)
# You can ask AI to create and populate this for you.
GCP_PROJECT_ID=

# Force deploy script to use your Cloud account for infra operations
# Your gmail account
DEPLOY_GCLOUD_ACCOUNT=

# AI Studio prepaid billing project/account (metasorcerer account)
# You can ask AI to create and populate this for you.
AI_STUDIO_BILLING_PROJECT=
# Your gmail account, can be same as DEPLOY_GCLOUD_ACCOUNT, but must be the account that has access to the AI Studio billing project.
AI_STUDIO_ACCOUNT_EMAIL=

# Server/runtime billing target used for Gemini requests
GOOGLE_APPLICATION_CREDENTIALS=/tmp/music-catalog-gemini-key.json
# Can be the same as the AI_STUDIO_BILLING_PROJECT, but must exist on DEPLOY_GCLOUD_ACCOUNT and have billing enabled.
GOOGLE_BILLING_PROJECT=
OPENROUTER_API_KEY=